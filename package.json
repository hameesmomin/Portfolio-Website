{
  "name": "personal-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "A production-minded personal portfolio website with a small Node backend.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "serve": "node --watch server/index.js",
    "start": "node server/index.js",
    "brochures:generate": "node scripts/generate-product-brochures.mjs",
    "brochures:audit": "node scripts/audit-product-brochures.mjs",
    "demo-access:audit": "node scripts/audit-demo-access.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "build": "vite build",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "playwright": "^1.60.0",
    "wrangler": "^4.90.1"
  },
  "overrides": {
    "ws": "^8.18.3"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.13"
  }
}
